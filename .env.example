# pm-research-engine configuration (copy to .env). All keys are PMRE_-prefixed.
# Production (PMRE_ENV=production) fails fast if any secret below is unset.

PMRE_ENV=dev

# --- Storage ---------------------------------------------------------------
# Production: PostgreSQL 16 + TimescaleDB. Dev/tests default to SQLite.
PMRE_DATABASE_URL=postgresql+psycopg2://pmre:CHANGEME@127.0.0.1:5432/pmre
PMRE_DATA_DIR=/data
PMRE_PARQUET_DIR=/data/parquet
PMRE_RAW_DIR=/data/raw

# --- Model versions --------------------------------------------------------
PMRE_FEE_MODEL_VERSION=fee-v1
PMRE_REGIME_MODEL_VERSION=regime-v1

# --- Snapshot / collector tuning ------------------------------------------
PMRE_SNAPSHOT_OFFSETS_S=270,240,210,180,150,120,90,60,30
PMRE_CLOCK_DRIFT_ABORT_MS=250
PMRE_CLOSE_CALL_BPS=2.0
PMRE_DIVERGENCE_FLAG_BPS=10.0

# --- Fee curve -------------------------------------------------------------
PMRE_DEFAULT_FEE_RATE=0.072

# --- Serving (bind to WireGuard/Tailscale overlay IP only) ----------------
PMRE_SERVING_HOST=100.64.0.1
PMRE_REST_PORT=8080
PMRE_MCP_PORT=8090
PMRE_REST_BEARER_TOKENS=read-token-a,read-token-b
PMRE_MCP_BEARER_TOKEN=CHANGEME-mcp
PMRE_INGEST_BEARER_TOKEN=CHANGEME-ingest

# --- Alerts (Telegram) -----------------------------------------------------
PMRE_ALERT_TELEGRAM_BOT_TOKEN=CHANGEME
PMRE_ALERT_TELEGRAM_CHAT_ID=CHANGEME
